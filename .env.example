# Copy to `.env` in this folder (repo root). `.env` is git-ignored.
# The tenure notebook loads this file via `python-dotenv` (see CELL 0). Alternatively:
#   export OPENALEX_API_KEY=...  etc. in the shell before starting Jupyter.

# OpenAlex — Bearer improves rate limits; mailto= identifies the polite pool
OPENALEX_API_KEY=
OPENALEX_MAILTO=you@institution.edu

# Optional: shown in Wayback/CDX User-Agent string (not sent to OpenAlex)
# HTTP_CONTACT_EMAIL=you@institution.edu
